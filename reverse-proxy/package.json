{
    "name": "effective-assistant-reverse-proxy",
    "version": "0.0.1",
    "description": "Host-managed reverse proxy that injects credentials into outbound traffic so the agent container never sees raw API keys.",
    "main": "build/index.js",
    "scripts": {
        "build": "tsc",
        "format": "biome format --write --config-path .. src/",
        "format:check": "biome format --config-path .. src/",
        "lint": "biome lint --config-path .. src/",
        "check": "biome check --config-path .. src/",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "author": "",
    "license": "MIT",
    "dependencies": {
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/node": "^25.6.0"
    }
}
