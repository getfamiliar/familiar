{
    "name": "@getfamiliar/shared",
    "type": "module",
    "version": "0.0.1",
    "description": "Familiar — shared types and bus-state client between host and container.",
    "publishConfig": {
        "access": "public"
    },
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "exports": {
        ".": {
            "types": "./build/index.d.ts",
            "default": "./build/index.js"
        },
        "./testing": {
            "types": "./build/testing/index.d.ts",
            "default": "./build/testing/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "format": "biome format --write --config-path .. src/",
        "format:check": "biome format --config-path .. src/",
        "lint": "biome lint --config-path .. src/",
        "check": "biome check --config-path .. src/",
        "test": "tsx --test 'src/**/*.test.ts'"
    },
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "chalk": "^5.4.1",
        "citty": "^0.1.6",
        "croner": "^10.0.1",
        "friendly-node-cron": "^1.5.0",
        "luxon": "^3.7.2",
        "marked": "^15.0.12",
        "marked-terminal": "^7.3.0",
        "pg": "^8.13.1",
        "pino": "^9.14.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/luxon": "^3.7.1",
        "@types/marked-terminal": "^6.1.1",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.11.10",
        "typescript": "^6.0.3"
    }
}
