{
    "name": "effective-assistant-shared",
    "version": "0.0.1",
    "description": "Shared types and bus-state client between host and container.",
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "scripts": {
        "build": "tsc",
        "format": "biome format --write --config-path .. src/",
        "format:check": "biome format --config-path .. src/",
        "lint": "biome lint --config-path .. src/",
        "check": "biome check --config-path .. src/"
    },
    "license": "MIT",
    "dependencies": {
        "citty": "^0.1.6",
        "pg": "^8.13.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.11.10",
        "typescript": "^6.0.3"
    }
}
