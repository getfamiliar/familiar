{
    "name": "effective-assistant-shared",
    "type": "module",
    "version": "0.0.1",
    "description": "Shared types and bus-state client between host and container.",
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "scripts": {
        "build": "tsc",
        "format": "biome format --write --config-path .. src/",
        "format:check": "biome format --config-path .. src/",
        "lint": "biome lint --config-path .. src/",
        "check": "biome check --config-path .. src/",
        "test": "tsx --test 'src/**/*.test.ts'"
    },
    "license": "MIT",
    "dependencies": {
        "chalk": "^5.4.1",
        "citty": "^0.1.6",
        "marked": "^15.0.12",
        "marked-terminal": "^7.3.0",
        "pg": "^8.13.1",
        "pino": "^9.14.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/marked-terminal": "^6.1.1",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.11.10",
        "typescript": "^6.0.3"
    }
}
