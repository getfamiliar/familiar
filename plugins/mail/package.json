{
    "name": "mail",
    "type": "module",
    "version": "0.0.1",
    "private": true,
    "description": "Mail host-side plugin: polls one or more mail MCPs (Microsoft 365 today) and emits an event per new mail.",
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "scripts": {
        "build": "tsc",
        "format": "biome format --write --config-path ../.. src/",
        "format:check": "biome format --config-path ../.. src/",
        "lint": "biome lint --config-path ../.. src/",
        "check": "biome check --config-path ../.. src/",
        "test": "tsx --test 'src/**/*.test.ts'"
    },
    "license": "MIT",
    "dependencies": {
        "citty": "^0.1.6",
        "effective-assistant-shared": "*"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    }
}
