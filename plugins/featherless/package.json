{
    "name": "@getfamiliar/plugin-featherless",
    "type": "module",
    "version": "0.0.1",
    "description": "Familiar plugin: supplies model metadata for Featherless-hosted models (the provider models.dev doesn't cover).",
    "publishConfig": {
        "access": "public"
    },
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "files": [
        "build",
        "workspace-template"
    ],
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "build": "tsc",
        "test": "tsx --test 'src/**/*.test.ts'",
        "format": "biome format --write --config-path ../.. src/",
        "format:check": "biome format --config-path ../.. src/",
        "lint": "biome lint --config-path ../.. src/",
        "check": "biome check --config-path ../.. src/"
    },
    "license": "MIT",
    "dependencies": {
        "@getfamiliar/shared": "*"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/node": "^25.6.0",
        "tsx": "^4.20.4",
        "typescript": "^6.0.3",
        "yaml": "^2.5.0"
    }
}
