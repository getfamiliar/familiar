{
    "name": "@getfamiliar/plugin-transcribe-whisper",
    "type": "module",
    "version": "0.0.1",
    "private": true,
    "description": "Familiar plugin: transcribeAudio() backed by OpenAI's Whisper API.",
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "scripts": {
        "build": "tsc",
        "format": "biome format --write --config-path ../.. src/",
        "format:check": "biome format --config-path ../.. src/",
        "lint": "biome lint --config-path ../.. src/",
        "check": "biome check --config-path ../.. src/"
    },
    "license": "MIT",
    "dependencies": {
        "citty": "^0.1.6",
        "@getfamiliar/shared": "*",
        "openai": "^4.77.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    }
}
