{
    "name": "cli-chat",
    "type": "module",
    "version": "0.0.1",
    "private": true,
    "description": "First plugin: emits chat:cli events from the command line.",
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "scripts": {
        "build": "tsc",
        "format": "biome format --write --config-path ../.. src/",
        "format:check": "biome format --config-path ../.. src/",
        "lint": "biome lint --config-path ../.. src/",
        "check": "biome check --config-path ../.. src/"
    },
    "license": "MIT",
    "dependencies": {
        "citty": "^0.1.6",
        "effective-assistant-shared": "*",
        "marked": "^15.0.12",
        "marked-terminal": "^7.3.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/marked-terminal": "^6.1.1",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    }
}
