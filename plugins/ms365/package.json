{
    "name": "@getfamiliar/plugin-ms365",
    "type": "module",
    "version": "0.0.1",
    "private": true,
    "description": "Familiar plugin: Microsoft 365 integration via direct Graph calls. Mail today, calendar next.",
    "publishConfig": {
        "access": "public"
    },
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "scripts": {
        "build": "tsc",
        "format": "biome format --write --config-path ../.. src/",
        "format:check": "biome format --config-path ../.. src/",
        "lint": "biome lint --config-path ../.. src/",
        "check": "biome check --config-path ../.. src/",
        "test": "tsx --test 'src/**/*.test.ts'"
    },
    "license": "MIT",
    "dependencies": {
        "@azure/msal-node": "^5.2.1",
        "@getfamiliar/shared": "*",
        "citty": "^0.1.6",
        "luxon": "^3.7.2"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/luxon": "^3.7.1",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    }
}
