    "check": "biome check --config-path .. src/",
    "test": "tsx --test 'src/**/*.test.ts'"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/deepseek": "^2.0.34",
