    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/mcp": "^1.0.40",
    "@ai-sdk/mistral": "^3.0.36",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@ai-sdk/xai": "^3.0.89",
    "ai": "^6.0.174",
    "@getfamiliar/shared": "*",
    "nodemon": "^3.1.7",
    "pino": "^9.14.0",
    "tsx": "^4.20.4",
    "typescript": "^6.0.3",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0"
