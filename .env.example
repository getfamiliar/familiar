# Password for the bus-state postgres (`ea-postgres`). Used by the daemon
# to start the container, by the agent container (passed via -e), and by
# host-side CLIs (event, etc.). Database name and user are hardcoded as
# `ea`.
POSTGRES_PASSWORD=ea

# The chat channel the user prefers to be contacted on. Set to a messenger app
# like "whatsapp" or "telegram" once you've set up such an integration.
DEFAULT_CHAT_CHANNEL_ID=cli

# Telegram plugin. Token comes from BotFather (/newbot). Leave the user id
# blank on first boot — the bot enters discovery mode and replies with the
# numeric id of any sender, which you paste back here and restart.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_AUTHORIZED_USER_ID=

# OpenAI API key, used only if you use the transcribe-whisper plugin to
# transcribe audio messages using OpenAI's Whisper API.
# OPENAI_API_KEY=