# Anthropic API key used by the host-side proxy. Copy this file to .env and
# fill in your real key. The agent containers never see this value directly —
# they reach api.anthropic.com via ea-anthropic-proxy on a private docker
# network.
ANTHROPIC_API_KEY=sk-ant-...

# Password for the bus-state postgres (`ea-postgres`). Used by the daemon
# to start the container, by the agent container (passed via -e), and by
# host-side CLIs (event, etc.). Database name and user are hardcoded as
# `ea`.
POSTGRES_PASSWORD=ea
