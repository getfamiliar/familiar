    "@getfamiliar/plugin-whatsapp": "*",
    "@getfamiliar/shared": "*",
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^3.6.0",
    "citty": "^0.1.6",
    "croner": "^10.0.1",
    "friendly-node-cron": "^1.5.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "pino-roll": "^3.1.0",
    "typescript": "^6.0.3",
    "yaml": "^2.8.4"
