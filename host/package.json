{
  "name": "effective-assistant-host",
  "type": "module",
  "version": "0.0.1",
  "description": "Host application for the effective assistant.",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "format": "biome format --write --config-path .. src/",
    "format:check": "biome format --config-path .. src/",
    "lint": "biome lint --config-path .. src/",
    "check": "biome check --config-path .. src/",
    "test": "tsx --test 'src/**/*.test.ts'"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "citty": "^0.1.6",
    "cli-chat": "*",
    "effective-assistant-shared": "file:../shared",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "pino-roll": "^3.1.0",
    "telegram": "*",
    "transcribe-whisper": "*",
    "typescript": "^6.0.3",
    "whatsapp": "*",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.6.0"
  }
}
